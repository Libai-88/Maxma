+++ b/web/src/components/ChatInput.vue
@@ -1029,11 +1029,24 @@ function handleSend() {
   if (selectedModelName.value) {
     chatStore.setModel(selectedModelName.value)
   }
-  chatInput.send(
+  // Fixed R-001: check send() return value, do not clear text on failure
+  const sent = chatInput.send(
     msg,
     refs.value,
     selectedThinkPathId.value || undefined,
   )
+  if (!sent) {
+    connectionError.value = 'Message send failed: WebSocket disconnected, please retry'
+    if (_connectionErrorTimer) clearTimeout(_connectionErrorTimer)
+    _connectionErrorTimer = setTimeout(() => {
+      if (_connectionErrorTimer && connectionError.value === 'Message send failed: WebSocket disconnected, please retry') {
+        connectionError.value = null
+        _connectionErrorTimer = null
+      }
+    }, 5000)
+    return
+  }
   text.value = ''
   selectedThinkPathId.value = null
   for (const r of refs.value) {
