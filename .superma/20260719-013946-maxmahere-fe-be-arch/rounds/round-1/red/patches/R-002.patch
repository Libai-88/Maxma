From: Red Team <red@superma>
Date: Sun, 19 Jul 2026 01:39:46 +0800
Subject: [PATCH R-002] Fix unhandled promise rejection from connectSession()

Problem: connectSession() can throw (e.g., ensureTokenLoaded() fails after
3 retries), but both call sites -- ensureConnected() and the reconnection
timer -- do not catch the error, leading to unhandled promise rejections.

Fix: Add .catch() handlers on both call sites. On failure, log the error
and set the channel error state so the UI can surface it.

---
 web/src/composables/useChat.ts | 23 ++++++++++++++++++++++-
 1 file changed, 22 insertions(+), 1 deletion(-)

diff --git a/web/src/composables/useChat.ts b/web/src/composables/useChat.ts
index ee50ad4..2d8d470 100644
--- a/web/src/composables/useChat.ts
+++ b/web/src/composables/useChat.ts
@@ -357,7 +357,16 @@ async function connectSession(sid: string) {
     const logFn = event.code === 1006 ? console.debug : console.log
     logFn('[useChat] WS closed: session=${sid}, code=${event.code}, reconnecting in ${delay}ms (attempt ${chFinal.reconnectAttempts})')
-    chFinal.reconnectTimer = setTimeout(() => connectSession(sid), delay)
+    // Fixed R-002: catch unhandled rejection from reconnection timer
+    chFinal.reconnectTimer = setTimeout(() => {
+      connectSession(sid).catch(err => {
+        console.error('[useChat] Reconnect failed (sid=${sid}):', err)
+        const ch = getChatStore().channels.get(sid)
+        if (ch && !ch.error) {
+          ch.error = 'Reconnect failed: ${err instanceof Error ? err.message : String(err)}'
+        }
+      })
+    }, delay)
   }
 
   ws.onerror = () => {
@@ -412,7 +421,15 @@ export function ensureConnected(sid: string) {
   }
   console.log('[useChat:ensureConnected] Initializing session ${sid} WebSocket connection')
   ch.initialized = true
-  connectSession(sid)
+  // Fixed R-002: catch unhandled rejection from connectSession
+  connectSession(sid).catch(err => {
+    console.error('[useChat] connectSession failed (sid=${sid}):', err)
+    const ch = getChatStore().channels.get(sid)
+    if (ch) {
+      ch.error = 'Connection failed: ${err instanceof Error ? err.message : String(err)}'
+      ch.connected = false
+    }
+  })
 }
 
 // ── Event routing ───────────────────────────────────
