From: Red Team <red@superma>
Date: Sun, 19 Jul 2026 01:39:46 +0800
Subject: [PATCH R-004] Add security warning for token in SSE URL

Problem: The activity store passes the auth token as a query parameter in
the SSE URL (?token=...). Token exposure in URLs is a security concern
(server logs, browser dev tools, Referer header).

Fix: Add documentation comment and a console.warn when token is used in
the URL. This is a documentation/monitoring fix; a full fix would require
backend changes for short-lived SSE tickets.

---
 web/src/stores/activity.ts | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/web/src/stores/activity.ts b/web/src/stores/activity.ts
index b95d3f8..22fc4b1 100644
--- a/web/src/stores/activity.ts
+++ b/web/src/stores/activity.ts
@@ -51,9 +51,15 @@ export const useActivityStore = defineStore('activity', () => {
     connecting.value = true
     try {
       // Construct SSE URL: EventSource does not support custom headers, token passed via query
+      // Security note: Token exposed in URL query parameter (visible in server logs, dev tools).
+      // This is a known compromise due to EventSource API limitations.
+      // Recommendation: backend should support short-lived SSE tickets for streaming.
       const base = getBackendOrigin()
       const token = getToken()
       const url = `${base}/api/activity/stream${token ? `?token=${encodeURIComponent(token)}` : ''}`
+      if (token) {
+        console.warn('[activity] SSE token exposed in URL query parameter -- visible in server logs and dev tools')
+      }
       eventSource = new EventSource(url)
       eventSource.addEventListener('activity', (ev: MessageEvent) => {
         try {
