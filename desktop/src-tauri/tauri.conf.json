{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "MaxmaHere",
  "version": "2.6.1",
  "identifier": "com.maxmahere.app",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "MaxmaHere",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8000 http://127.0.0.1:8001 http://127.0.0.1:8002 http://127.0.0.1:8003 http://127.0.0.1:8004 http://127.0.0.1:8005 http://127.0.0.1:8006 http://127.0.0.1:8007 http://127.0.0.1:8008 http://127.0.0.1:8009 http://127.0.0.1:8010 ws://127.0.0.1:8000 ws://127.0.0.1:8001 ws://127.0.0.1:8002 ws://127.0.0.1:8003 ws://127.0.0.1:8004 ws://127.0.0.1:8005 ws://127.0.0.1:8006 ws://127.0.0.1:8007 ws://127.0.0.1:8008 ws://127.0.0.1:8009 ws://127.0.0.1:8010; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' http://127.0.0.1:8000 http://127.0.0.1:8001 http://127.0.0.1:8002 http://127.0.0.1:8003 http://127.0.0.1:8004 http://127.0.0.1:8005 http://127.0.0.1:8006 http://127.0.0.1:8007 http://127.0.0.1:8008 http://127.0.0.1:8009 http://127.0.0.1:8010 data: blob:; media-src 'self' data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/default-config/*",
      "resources/runtime/**/*",
      "resources/assets/**/*"
    ],
    "publisher": "MaxmaHere",
    "externalBin": [
      "binaries/maxma-server"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
