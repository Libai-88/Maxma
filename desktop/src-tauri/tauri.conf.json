{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "MaxmaHere",
  "version": "2.6.6",
  "identifier": "com.maxmahere.app",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "cd ../web && npm run dev -- --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "cd ../web && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MaxmaHere",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      },
      {
        "label": "quick-chat",
        "url": "quick-chat.html",
        "title": "Quick Chat",
        "width": 480,
        "height": 640,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "center": false,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; font-src 'self' https://fonts.gstatic.com; style-src 'self' https://fonts.googleapis.com; img-src 'self' http://127.0.0.1:* http://localhost:* data: blob:; media-src 'self' data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/default-config/*",
      "resources/runtime/**/*",
      "resources/assets/**/*"
    ],
    "publisher": "MaxmaHere",
    "externalBin": [
      "binaries/maxma-server"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    }
  }
}
