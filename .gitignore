api/data/sticker_recent.yaml

# Tauri 本地构建产物
desktop/src-tauri/target/
desktop/src-tauri/binaries/*.exe

# Anthropic Skills（忽略 skill 子目录，保留目录本身用于 .gitkeep）
anthropic_skills/*/

# Macros（同上）
macros/*/

# 用户上传文件和浏览器截图（运行时生成）
uploads/

# 日志文件（运行时生成）
logs/

# 安全威胁模型（本地文档，不提交）
dev_docs/security/
api/data/maxma.db

# 临时测试/调试输出文件
pytest_*.txt
pytest_*.xml
stderr.log
stdout.log
test_output.txt
venv_stdout.log

# 向量数据库本地缓存
vector_db/

# 生产打包：构建时下载的嵌入式运行时和资源（不进 git，但保留 .gitkeep 占位）
desktop/src-tauri/resources/runtime/*
!desktop/src-tauri/resources/runtime/.gitkeep
desktop/src-tauri/resources/assets/*
!desktop/src-tauri/resources/assets/.gitkeep
