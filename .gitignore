# 认证 Token（自动生成，每用户本地配置）
api/data/auth_token.yaml

# MCP 服务器配置（每用户本地配置，可能含 API Key 等敏感信息）
config/mcp_servers.yaml
api/data/mcp_servers.yaml

# 事件钩子配置（每用户本地配置）
api/data/event_hooks.yaml

# Sticker 本地运行数据（自动生成）
